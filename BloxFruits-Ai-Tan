-- 4. [ FUNCTIONALITY ]
local function UpdateUI()
    LangBtn.Text = LangData[CurrentLang].Lang
    -- อัปเดตชื่อปุ่มทั้งหมดใน ContentArea (วนลูปเปลี่ยนข้อความ)
    for _, btn in pairs(ContentArea:GetChildren()) do
        if btn:IsA("TextButton") then
            if btn.Name == "Farm" then btn.Text = LangData[CurrentLang].Farm
            elseif btn.Name == "Stat" then btn.Text = LangData[CurrentLang].Stat
            elseif btn.Name == "Tele" then btn.Text = LangData[CurrentLang].Tele
            elseif btn.Name == "Lag" then btn.Text = LangData[CurrentLang].Lag end
        end
    end
end

LangBtn.MouseButton1Click:Connect(function()
    if CurrentLang == "TH" then CurrentLang = "LAO"
    elseif CurrentLang == "LAO" then CurrentLang = "EN"
    else CurrentLang = "TH" end
    UpdateUI()
end)

local function CreateBtn(name, id, callback)
    local B = Instance.new("TextButton", ContentArea)
    B.Name = name
    B.Size = UDim2.new(1, -5, 0, 45)
    B.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    B.Font = Enum.Font.GothamMedium
    B.TextColor3 = Color3.fromRGB(80, 80, 80)
    Instance.new("UICorner", B)
    B.MouseButton1Click:Connect(callback)
end

