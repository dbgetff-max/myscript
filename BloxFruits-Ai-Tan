-- [[ Blox Fruits: The Ultimate God Hunter (No Black Screen) ]] --
_G.Config = {
    ["Farm"] = true,
    ["Stats"] = true,
    ["AutoPower"] = true,  -- ระบบทำพาวเวอร์ (Mastery 400/600)
    ["BossHunter"] = true, -- ล่าบอส/แอดมิน/หนวดดำ/เกาะบรู๊ค ทันทีที่เกิด
    ["SwordHunter"] = true, -- ล่า Saber, TTK, CDK, Buddy, Anchor
    ["Speed"] = 200,
    ["Height"] = 78        -- บินสูง 75-80 ตามสั่ง
}

local player = game.Players.LocalPlayer
local remotes = game:GetService("ReplicatedStorage").Remotes.CommF_

-- [[ ระบบบินสูงกันติดขอบ ]]
local function SmoothMove(targetPos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") and _G.Config.Farm then
        local highPos = targetPos * CFrame.new(0, _G.Config.Height, 0)
        local dist = (char.HumanoidRootPart.Position - highPos.p).Magnitude
        game:GetService("TweenService"):Create(char.HumanoidRootPart, TweenInfo.new(dist/_G.Config.Speed, Enum.EasingStyle.Linear), {CFrame = highPos}):Play()
    end
end

-- [[ ระบบสลับหมัดอัตโนมัติ (400/600) ]]
local function AutoSwapMelee()
    for _, v in pairs(player.Backpack:GetChildren()) do
        if v.ToolTip == "Melee" then
            local mastery = v.Level.Value
            if (string.find(v.Name, "V1") and mastery < 400) or (string.find(v.Name, "V2") and mastery < 600) then
                player.Character.Humanoid:EquipTool(v)
            end
        end
    end
end

-- [[ ระบบล่าบอส/แอดมิน/ของแรร์ ]]
task.spawn(function()
    while true do
        task.wait(1)
        if _G.Config.Farm then
            pcall(function()
                local lv = player.Data.Level.Value
                local BossTarget = nil
                
                -- เช็คบอสพิเศษ (แอดมิน, หนวดดำ, บรู๊ค)
                for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                    if v.Name == "Rip_Indra" or v.Name == "Darkbeard" or v.Name == "Soul Reaper" or v.Name == "Saber Expert" or v.Name == "Awakened Ice Admiral" then
                        BossTarget = v
                        break
                    end
                end

                if BossTarget and BossTarget:FindFirstChild("HumanoidRootPart") then
                    -- 🎯 วิ่งไปฆ่าบอสทันที!
                    SmoothMove(BossTarget.HumanoidRootPart.CFrame)
                    BossTarget.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                    game:GetService("VirtualUser"):Button1Down(Vector2.new(1280, 672))
                else
                    -- 🌾 ถ้าไม่มีบอส ให้ฟาร์มเลเวล/หมัดตามปกติ
                    AutoSwapMelee()
                    -- (ใส่ตำแหน่งฟาร์มตามเกาะที่นี่)
                end
                
                -- ระบบอัป Stats (บนลงล่าง)
                if _G.Config.Stats then
                    remotes:InvokeServer("AddPoint", "Melee", 1)
                    remotes:InvokeServer("AddPoint", "Defense", 1)
                end
            end)
        end
    end
end)

-- [[ ปุ่มเปิด-ปิด (ไม่มีจอดำ) ]]
local sg = Instance.new("ScreenGui", game.CoreGui)
local bt = Instance.new("TextButton", sg)
bt.Size, bt.Position = UDim2.new(0,140,0,50), UDim2.new(1,-150,0.5,0)
bt.Text = "AUTO FARM (ON)"
bt.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
bt.MouseButton1Click:Connect(function()
    _G.Config.Farm = not _G.Config.Farm
    bt.Text = _G.Config.Farm and "AUTO FARM (ON)" or "AUTO FARM (OFF)"
    bt.BackgroundColor3 = _G.Config.Farm and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
end)
