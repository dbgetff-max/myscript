-- [[ Blox Fruits Ai-Tan: Auto Farm & Auto Quest ]] --
_G.Settings = {
    ["AutoFarm"] = true,
    ["TweenSpeed"] = 200, -- บินนุ่มๆ กันโดนเตะ 267
    ["AutoStats"] = true
}

local player = game.Players.LocalPlayer

-- ระบบบินไปตามเกาะ (Tween) เพื่อกันโดนเตะ 267
local function SmoothMove(targetPos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local dist = (char.HumanoidRootPart.Position - targetPos.p).Magnitude
        game:GetService("TweenService"):Create(char.HumanoidRootPart, TweenInfo.new(dist/_G.Settings.TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetPos}):Play()
    end
end

-- ระบบเช็คจุดฟาร์มตามเลเวล (โลก 1) เพื่อไม่ให้ค้างที่เกาะหิมะ
local function GetFarmPos(lv)
    if lv < 10 then return CFrame.new(-1100, 15, 1500) -- เกาะเริ่มต้น
    elseif lv < 40 then return CFrame.new(-1500, 40, 400) -- เกาะลิง
    elseif lv < 150 then return CFrame.new(900, 15, -1400) -- เกาะทะเลทราย
    elseif lv < 250 then return CFrame.new(1300, 15, -1300) -- เกาะหิมะ (ที่คุณเคยติด)
    else return CFrame.new(-400, 15, 2500) -- เกาะคุก
    end
end

task.spawn(function()
    while _G.Settings.AutoFarm do
        task.wait(1)
        pcall(function()
            local lv = player.Data.Level.Value
            
            -- บินไปเกาะที่เหมาะสม
            SmoothMove(GetFarmPos(lv))

            -- ระบบดึงมอนสเตอร์มาตี (Bring Mob)
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v:FindFirstChild("HumanoidRootPart") then
                    v.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                    v.Humanoid.Health = 0 -- (ตัวอย่างการโจมตี)
                end
            end
        end)
    end
end)
