-- [[ Blox Fruits: Ai-Tan Ultimate Edition (Full Item & Boss Hunter) ]] --
_G.Config = {
    ["Farm"] = true,
    ["Stats"] = true,
    ["AutoPower"] = true,  -- ระบบทำพาวเวอร์ (สลับหมัด 400/600)
    ["BossHunter"] = true, -- ล่าบอส/แอดมิน/หนวดดำ/เกาะบรู๊ค ทันทีที่เกิด
    ["SwordHunter"] = true, -- ล่าดาบ Saber, TTK, CDK, Buddy, Anchor
    ["Speed"] = 200,       -- ความเร็วปลอดภัย
    ["Height"] = 78        -- บินสูงตามสั่ง (75-80)
}

local player = game.Players.LocalPlayer
local remotes = game:GetService("ReplicatedStorage").Remotes.CommF_

-- [[ ระบบบินสูง 78 เมตร และล็อกความสูง ]]
local function SmoothMove(targetPos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") and _G.Config.Farm then
        -- ล็อกความสูง (Y) ไว้ที่ 78 ตลอดการเดินทาง
        local highPos = CFrame.new(targetPos.p.X, targetPos.p.Y + _G.Config.Height, targetPos.p.Z)
        local dist = (char.HumanoidRootPart.Position - highPos.p).Magnitude
        if dist > 5 then
            game:GetService("TweenService"):Create(char.HumanoidRootPart, TweenInfo.new(dist/_G.Config.Speed, Enum.EasingStyle.Linear), {CFrame = highPos}):Play()
        end
    end
end

-- [[ ระบบดึงมอนมาตี (Bring Mob) ]]
local function AttackMonster(mob)
    if mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
        mob.HumanoidRootPart.CanCollide = false
        -- ดึงมอนมาไว้ข้างหน้าตัวเราในระยะที่ตีโดนแน่นอน
        mob.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
        game:GetService("VirtualUser"):Button1Down(Vector2.new(1280, 672))
    end
end

-- [[ ระบบเช็คและสลับหมัด (400/600) ]]
local function AutoSwapMelee()
    if not _G.Config.AutoPower then return end
    local currentTool = player.Character:FindFirstChildOfClass("Tool")
    if currentTool and currentTool.ToolTip == "Melee" then
        local mastery = currentTool.Level.Value
        -- ถ้าหมัด V1 ครบ 400 หรือ V2 ครบ 600 ให้หาหมัดใหม่ในช่องเก็บของ
        if (not string.find(currentTool.Name, "V2") and mastery >= 400) or (string.find(currentTool.Name, "V2") and mastery >= 600) then
            for _, tool in pairs(player.Backpack:GetChildren()) do
                if tool.ToolTip == "Melee" and tool.Name ~= currentTool.Name then
                    player.Character.Humanoid:EquipTool(tool)
                    break
                end
            end
        end
    end
end

-- [[ ระบบล่าบอส & ของแรร์ (Special Targets) ]]
local function GetSpecialTarget()
    local names = {"rip_indra", "Darkbeard", "Soul Reaper", "Saber Expert", "Cake Queen", "Order"}
    for _, enemy in pairs(game.Workspace.Enemies:GetChildren()) do
        for _, name in pairs(names) do
            if enemy.Name:find(name) and enemy.Humanoid.Health > 0 then
                return enemy
            end
        end
    end
    return nil
end

-- [[ Loop การทำงานหลัก ]]
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.Config.Farm then
            pcall(function()
                local lv = player.Data.Level.Value
                local char = player.Character
                local specialBoss = GetSpecialTarget()

                -- 1. ถ้าบอสพิเศษ/แอดมินเกิด -> พุ่งไปฆ่าทันที!
                if specialBoss and _G.Config.BossHunter then
                    SmoothMove(specialBoss.HumanoidRootPart.CFrame)
                    AttackMonster(specialBoss)
                else
                    -- 2. ถ้าไม่มีบอส -> ฟาร์มเลเวล/หมัดตามปกติ
                    AutoSwapMelee()
                    
                    -- พิกัดจุดฟาร์มตามโลก
                    local farmPos
                    if lv < 700 then farmPos = CFrame.new(-1500, 40, 400) -- โลก 1
                    elseif lv < 1500 then farmPos = CFrame.new(-380, 70, 250) -- โลก 2
                    else farmPos = CFrame.new(-5000, 300, -5000) end -- โลก 3
                    
                    SmoothMove(farmPos)
                    
                    -- ตีมอนสเตอร์ที่อยู่ใกล้ตัว
                    for _, mob in pairs(game.Workspace.Enemies:GetChildren()) do
                        if (mob.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude < 300 then
                            AttackMonster(mob)
                        end
                    end
                end

                -- 3. อัป Stats (บนลงล่าง)
                if _G.Config.Stats then
                    remotes:InvokeServer("AddPoint", "Melee", 1)
                    remotes:InvokeServer("AddPoint", "Defense", 1)
                end
            end)
        end
    end
end)

