-- [[ เน้นกันโดนเตะ 267 + ฟาร์มยาว 1-2550 ]] --

_G.Settings = {
    ["AutoFarm"] = true,
    ["TweenSpeed"] = 220, -- ความเร็วบินแบบปลอดภัย (Safe Mode)
    ["AutoStats"] = true,
    ["BringMob"] = true
}

local player = game.Players.LocalPlayer

-- ระบบเคลื่อนที่แบบ Tween (บินนุ่มๆ) เพื่อแก้ปัญหาโดน Security Kick
local function SmoothMove(targetPos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local dist = (char.HumanoidRootPart.Position - targetPos.p).Magnitude
        local info = TweenInfo.new(dist/_G.Settings.TweenSpeed, Enum.EasingStyle.Linear)
        local tween = game:GetService("TweenService"):Create(char.HumanoidRootPart, info, {CFrame = targetPos})
        tween:Play()
    end
end

-- ปุ่มเปิด/ปิดจอดำ (อยู่ขวาจอ)
local screenGui = Instance.new("ScreenGui", game.CoreGui)
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.Size = UDim2.new(0, 100, 0, 45)
toggleBtn.Position = UDim2.new(1, -110, 0.5, 0)
toggleBtn.Text = "เปิดจอดำ"
toggleBtn.ZIndex = 999

local blackFrame = Instance.new("Frame", screenGui)
blackFrame.Size = UDim2.new(1, 0, 1, 0)
blackFrame.BackgroundColor3 = Color3.new(0, 0, 0)
blackFrame.Visible = false

toggleBtn.MouseButton1Click:Connect(function()
    blackFrame.Visible = not blackFrame.Visible
    toggleBtn.Text = blackFrame.Visible and "ปิดจอดำ" or "เปิดจอดำ"
end)

-- ระบบฟาร์มและทำเควส (ไก่ตัน)
task.spawn(function()
    while _G.Settings.AutoFarm do
        task.wait(0.5)
        pcall(function()
            local lv = player.Data.Level.Value
            
            -- อัพ Stats อัตโนมัติ
            if _G.Settings.AutoStats then
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("AddPoint", "Melee", 2)
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("AddPoint", "Defense", 1)
            end

            -- เงื่อนไขโลก
            if lv < 700 then
                -- โลก 1: บินไปจุดฟาร์ม (กันโดนเตะ 267)
                SmoothMove(CFrame.new(630, 560, -1450))
            elseif lv >= 700 and lv < 1500 then
                -- ไปโลก 2 อัตโนมัติ
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("TravelSecondSea")
            end
        end)
    end
end)
