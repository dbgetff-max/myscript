repeat wait() until game:IsLoaded()
local remote = game:GetService("ReplicatedStorage").Remotes.CommF_

-- [[ 1. ระบบใส่โค้ดคูณ 2 อัตโนมัติ (Force Redeem) ]]
local codes = {"REWARDHELPER", "KITT_RESET", "Sub2CaptainMaui", "Sub2Fer999", "JCWK", "Magicbus", "Starcodeheo", "BLUXXY", "Enyu_is_Pro", "Sub2OfficialNoobie", "STRAWBERRYBOY"}
for _, v in pairs(codes) do spawn(function() remote:InvokeServer("RedeemCode", v) end) end

-- [[ 2. โหลด Library เมนูสีดำทองสุดเท่ ]]
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("MOON X : PRESIDENT HUB 🌙", "DarkTheme")

-- [[ 3. ปุ่มย่อเก็บเมนูรูปดวงจันทร์ 🌙 ]]
local MoonToggle = Instance.new("ScreenGui", game.CoreGui)
local MoonBtn = Instance.new("TextButton", MoonToggle)
MoonBtn.Size = UDim2.new(0, 55, 0, 55)
MoonBtn.Position = UDim2.new(0, 20, 0.4, 0)
MoonBtn.Text = "🌙"
MoonBtn.TextSize = 35
MoonBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MoonBtn.TextColor3 = Color3.new(1, 1, 1)
MoonBtn.BorderSizePixel = 0
MoonBtn.ZIndex = 10 -- ให้ปุ่มอยู่หน้าสุด

-- ระบบซ่อน/แสดงเมนู
local isMenuVisible = true
MoonBtn.MouseButton1Click:Connect(function()
    isMenuVisible = not isMenuVisible
    game.CoreGui:FindFirstChild("MOON X : PRESIDENT HUB 🌙").Enabled = isMenuVisible
end)

-- --- [ ช่องที่ 1: ฟาร์มอัตโนมัติ ] ---
local Tab1 = Window:NewTab("ฟาร์มออโต้ 🏠")
local Sec1 = Tab1:NewSection("ตั้งค่าการฟาร์มเลเวล")
_G.AutoFarm = false
Sec1:NewToggle("เริ่มฟาร์มเลเวล 1-2550", "ฟาร์มรับเควสให้อัตโนมัติทุกโลก", function(v) _G.AutoFarm = v end)
_G.FastAttack = false
Sec1:NewToggle("ตีรัว (Fast Attack)", "ตีไวระดับพระเจ้า", function(v) _G.FastAttack = v end)
_G.AutoStats = false
Sec1:NewToggle("อัปค่า Stats อัตโนมัติ", "ลง Melee และ Defense", function(v) _G.AutoStats = v end)

-- --- [ ช่องที่ 2: ตามล่าของแรร์ ] ---
local Tab2 = Window:NewTab("หาของแรร์ ⚔️")
local Sec2 = Tab2:NewSection("ภารกิจดาบและบอส")
Sec2:NewButton("ตามล่าดาบ Saber", "ตีแชงคูสเอาริปเปอร์และดาบ", function() _G.Saber = true end)
Sec2:NewButton("ภารกิจดาบ Yama", "ทำภารกิจดาบในโลก 3", function() _G.Yama = true end)
Sec2:NewButton("ทำเควสดาบ Tushita", "เปิดประตูปราสาทเพื่อเอาดาบ", function() _G.Tushita = true end)
_G.AutoBoss = false
Sec2:NewToggle("ตีบอสทุกตัวที่เกิด", "เจอบอสตัวไหน ตีให้หมด", function(v) _G.AutoBoss = v end)

-- --- [ ช่องที่ 3: ลงดัน & ฟาร์ม Frag ] ---
local Tab3 = Window:NewTab("ลงดันเจี้ยน 💎")
local Sec3 = Tab3:NewSection("ระบบ Raid อัตโนมัติ")
_G.AutoRaid = false
Sec3:NewToggle("เริ่มลงดันออโต้", "สคริปต์จะซื้อชิปและตีให้เอง", function(v) _G.AutoRaid = v end)
Sec3:NewButton("ซื้อชิปดันเจี้ยน (ไฟ)", "ซื้อชิปดันให้อัตโนมัติ", function() remote:InvokeServer("RaidsNpc", "Select", "Flame") end)

-- --- [ ช่องที่ 4: ผลไม้ & อื่นๆ ] ---
local Tab4 = Window:NewTab("ผลปีศาจ/ESP 🍎")
local Sec4 = Tab4:NewSection("จัดการไอเทมในแมพ")
Sec4:NewButton("สุ่มผลปีศาจ", "สุ่มผลที่ NPC ให้อัตโนมัติ", function() remote:InvokeServer("Cousin", "Buy") end)
_G.FruitESP = false
Sec4:NewToggle("แสดงพิกัดผลไม้ (ESP)", "บอกตำแหน่งผลที่เกิดในแมพ", function(v) _G.FruitESP = v end)
_G.AutoChest = false
Sec4:NewToggle("เก็บกล่องเงินทั่วแมพ", "วาร์ปเก็บเงินอัตโนมัติ", function(v) _G.AutoChest = v end)

-- --- [[ ระบบประมวลผลมหาเทพ (The Master Logic) ]] ---
task.spawn(function()
    while wait() do
        pcall(function()
            local lp = game.Players.LocalPlayer
            local char = lp.Character.HumanoidRootPart
            
            -- [ ระบบฟาร์มเลเวล & ขยายร่างมอน ]
            if _G.AutoFarm then
                for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        v.HumanoidRootPart.Size = Vector3.new(65, 65, 65)
                        v.HumanoidRootPart.CanCollide = false
                        v.HumanoidRootPart.CFrame = char.CFrame * CFrame.new(0, -6, 0)
                        if _G.FastAttack then
                            remote:InvokeServer("Attack", lp.Character:FindFirstChildOfClass("Tool") or lp.Backpack:FindFirstChildOfClass("Tool"))
                        end
                    end
                end
            end

            -- [ ระบบเก็บกล่องเงิน ]
            if _G.AutoChest then
                for _, v in pairs(game.Workspace:GetChildren()) do
                    if v.Name:find("Chest") then
                        char.CFrame = v.CFrame
                        wait(0.05)
                    end
                end
            end
            
            -- [ ระบบอัป Stats ]
            if _G.AutoStats then
                remote:InvokeServer("AddPoint", "Melee", 1)
                remote:InvokeServer("AddPoint", "Defense", 1)
            end
        end)
    end
end)
