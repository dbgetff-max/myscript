-- [[ Blox Fruits: Ai-Tan Universe (Full Farm + Auto Buy Haki) ]] --
_G.Config = {
    ["Farm"] = true,
    ["Stats"] = true,
    ["AutoHaki"] = true, -- เปิดระบบซื้อฮาคิอัตโนมัติ
    ["Height"] = 78,
    ["Distance"] = 7,
    ["Speed"] = 230
}

local player = game.Players.LocalPlayer
local remotes = game:GetService("ReplicatedStorage").Remotes.CommF_

-- [[ ระบบซื้อฮาคิ (Buso / Skyjump / FlashStep / Observation) ]]
local function AutoBuyHaki()
    if not _G.Config.AutoHaki then return end
    local lv = player.Data.Level.Value
    local cash = player.Data.Beli.Value
    
    -- ซื้อฮาคิเกราะ/กระโดด/โซ (ที่เกาะหิมะ โลก 1)
    if game.PlaceId == 2753915549 then
        if cash >= 25000 then remotes:InvokeServer("BuyHaki", "Buso") end
        if cash >= 10000 then remotes:InvokeServer("BuyHaki", "Skyjump") end
        if cash >= 100000 then remotes:InvokeServer("BuyHaki", "FlashStep") end
        
        -- ซื้อฮาคิสังเกต (เวล 300 + เงิน 7.5 แสน ที่เกาะท้องฟ้า)
        if lv >= 300 and cash >= 750000 then
            remotes:InvokeServer("WaitUntilReady", "BuyObsHaki")
        end
    end
end

-- [[ ระบบเปิดใช้งานฮาคิอัตโนมัติขณะฟาร์ม ]]
local function EnableHaki()
    if not player.Character:FindFirstChild("HasBuso") then
        remotes:InvokeServer("Buso")
    end
end

-- [[ ระบบเช็คเกาะและเควส (World 1-2-3) ]]
local function GetCurrentWorldData()
    local lv = player.Data.Level.Value
    local world = game.PlaceId
    
    if world == 2753915549 then -- Sea 1
        if lv < 60 then return {NPC = CFrame.new(-1598, 35, 153), Name = "JungleQuest", Item = 1}
        elseif lv < 120 then return {NPC = CFrame.new(-1150, 20, -3000), Name = "SnowQuest", Item = 1}
        elseif lv < 300 then return {NPC = CFrame.new(890, 15, 4380), Name = "DesertQuest", Item = 1}
        elseif lv < 450 then return {NPC = CFrame.new(5120, 15, 600), Name = "PrisonQuest", Item = 1}
        else return {NPC = CFrame.new(-5200, 15, 8500), Name = "MagmaQuest", Item = 1} end
    elseif world == 4442272183 then -- Sea 2
        return {NPC = CFrame.new(-1580, 7, 335), Name = "Area1Quest", Item = 1}
    else -- Sea 3
        return {NPC = CFrame.new(-12500, 15, -10500), Name = "TurtleQuest", Item = 1}
    end
end

-- [[ ระบบโจมตี (CA/PA) ]]
local function AttackLogic()
    local char = player.Character
    EnableHaki() -- เปิดฮาคิเกราะก่อนตี
    for _, mob in pairs(game.Workspace.Enemies:GetChildren()) do
        if mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
            if (mob.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude < 300 then
                mob.HumanoidRootPart.CanCollide = false
                mob.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, -_G.Config.Distance, 0)
                
                local tool = char:FindFirstChildOfClass("Tool")
                if not tool or tool.ToolTip ~= "Melee" then
                    for _, t in pairs(player.Backpack:GetChildren()) do
                        if t.ToolTip == "Melee" then char.Humanoid:EquipTool(t) break end
                    end
                end
                if tool then
                    spawn(function()
                        game:GetService("ReplicatedStorage").Remotes.Validator:FireServer(math.huge)
                        remotes:InvokeServer("Attack", tool)
                    end)
                    game:GetService("VirtualUser"):Button1Down(Vector2.new(1280, 672))
                end
            end
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.01)
        if _G.Config.Farm then
            pcall(function()
                local char = player.Character
                local data = GetCurrentWorldData()
                
                -- ระบบซื้อฮาคิอัตโนมัติ
                AutoBuyHaki()
                
                -- รับเควส
                if _G.Config.AutoQuest and player.PlayerGui.Main.Quest.Visible == false then
                    char.HumanoidRootPart.CFrame = data.NPC
                    task.wait(0.5)
                    remotes:InvokeServer("StartQuest", data.Name, data.Item)
                end
                
                -- บินเดินทาง/ฟาร์ม
                local dist = (char.HumanoidRootPart.Position - data.NPC.p).Magnitude
                if dist > 65 then
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame:Lerp(CFrame.new(data.NPC.p.X, _G.Config.Height, data.NPC.p.Z), 0.1)
                else
                    AttackLogic()
                end

                -- อัป Stats
                if _G.Config.Stats then
                    remotes:InvokeServer("AddPoint", "Melee", 1)
                    remotes:InvokeServer("AddPoint", "Defense", 1)
                end
            end)
        end
    end
end)

