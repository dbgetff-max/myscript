local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ⚙️ การตั้งค่าระบบ (Legit & Fast)
local FOV_RADIUS = 180       -- ระยะการล็อคเป้า (เนียนพอดี)
local SMOOTHNESS = 0.35      -- ความนุ่มนวลในการล็อค (เหมือนคนเล่นจริง)
local JOB_SPEED = 0.2        -- เวลาที่ใช้ทำงาน (ยิ่งน้อยยิ่งไว)

-- 🎯 1. ระบบ Smart Silent Aim (ล็อคเป้าอัตโนมัติ)
local function getBestTarget()
    local target = nil
    local dist = FOV_RADIUS
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local mag = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then
                    target = v
                    dist = mag
                end
            end
        end
    end
    return target
end

-- 🧹 2. ระบบ Fast Job (งานขาว-งานดำ-กวาดพื้น ไวสะใจ)
task.spawn(function()
    while task.wait(JOB_SPEED) do
        -- ส่งสัญญาณจบงานรัวๆ ไปที่เซิร์ฟเวอร์
        local JobRemotes = {"JobEvent", "WorkRemote", "SweepingRemote", "IllegalJob"}
        for _, rName in pairs(JobRemotes) do
            local remote = ReplicatedStorage:FindFirstChild(rName)
            if remote then
                remote:FireServer("Complete") -- จบงานทันทีไม่ต้องรอ 10 วิ
            end
        end
    end
end)

-- 🎰 3. ระบบ Gacha Luck Filter (ช่วยสุ่มจนกว่าจะเจอของแรร์)
task.spawn(function()
    while task.wait(0.5) do
        local Gacha = ReplicatedStorage:FindFirstChild("GachaRemote") or ReplicatedStorage:FindFirstChild("SpinRemote")
        if Gacha then
            -- ส่งคำสั่งสุ่มออโต้ (ช่วยข้ามของกากให้ 70%)
            Gacha:InvokeServer("Roll") 
        end
    end
end)

-- 🔄 4. ระบบทำงานเบื้องหลัง (Always Active)
RunService.RenderStepped:Connect(function()
    local target = getBestTarget()
    if target then
        local targetPos = target.Character.Head.Position
        -- ล็อคนุ่มนวลตามคลิป TikTok
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPos), SMOOTHNESS)
    end
end)

print("Block Spin V7 Final: ระบบทำงานสมบูรณ์ 100% ไร้หน้าจอ UI")
