-- [[ CHEATING PRO MASTER V1 - LOCK TARGET & AUTO KILL ]] --
-- แก้ไข: เพิ่มระบบล็อคเป้า (Aimlock) ให้ยิงโดน 100% ในระยะที่กำหนด

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- ตั้งค่าระยะการยิงและล็อคเป้า
_G.ShootRange = 200 

-- 1. ระบบ ESP แยกสีทีม (เหมือนเดิมที่คุณชอบ)
local function CreateESP(Player)
    Player.CharacterAdded:Connect(function(Character)
        local Head = Character:WaitForChild("Head", 10)
        local bgui = Instance.new("BillboardGui", Head)
        bgui.Name = "MasterESP"
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 200, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 2.5, 0)

        local nametag = Instance.new("TextLabel", bgui)
        nametag.BackgroundTransparency = 1
        nametag.Size = UDim2.new(1, 0, 1, 0)
        nametag.TextSize = 16
        nametag.Font = Enum.Font.SourceSansBold
        nametag.TextStrokeTransparency = 0 
        
        RunService.Heartbeat:Connect(function()
            if Player and Player.Parent and Character and Character:FindFirstChild("Head") then
                local team = Player.Team and Player.Team.Name or "Neutral"
                nametag.Text = Player.Name .. " [" .. team .. "]"
                
                if team == "Police" or team == "Guards" then nametag.TextColor3 = Color3.fromRGB(0, 191, 255)
                elseif team == "Criminals" then nametag.TextColor3 = Color3.fromRGB(255, 0, 50)
                elseif team == "Prisoners" then nametag.TextColor3 = Color3.fromRGB(255, 170, 0)
                else nametag.TextColor3 = Color3.fromRGB(255, 255, 255) end
            else bgui:Destroy() end
        end)
    end)
end

-- 2. ระบบค้นหาเป้าหมายที่ใกล้ที่สุด
local function GetClosestEnemy()
    local closestPlayer = nil
    local shortestDistance = _G.ShootRange

    for _, target in pairs(Players:GetPlayers()) do
        if target ~= LocalPlayer and target.Team and target.Team ~= LocalPlayer.Team then
            local tChar = target.Character
            if tChar and tChar:FindFirstChild("HumanoidRootPart") and tChar.Humanoid.Health > 0 then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - tChar.HumanoidRootPart.Position).Magnitude
                if dist < shortestDistance then
                    closestPlayer = tChar
                    shortestDistance = dist
                end
            end
        end
    end
    return closestPlayer
end

-- 3. ระบบยิง + ล็อคเป้าอัตโนมัติ
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    
    if tool and tool:FindFirstChild("RemoteEvent") then
        local targetChar = GetClosestEnemy()
        
        if targetChar then
            local targetPos = targetChar.HumanoidRootPart.Position
            
            -- [[ ส่วนที่ทำให้ล็อคเป้า: หันตัวเราไปหาเป้าหมาย ]] --
            -- char.HumanoidRootPart.CFrame = CFrame.new(char.HumanoidRootPart.Position, Vector3.new(targetPos.X, char.HumanoidRootPart.Position.Y, targetPos.Z))
            
            -- ยิงไปที่ตำแหน่งเป้าหมาย
            tool.RemoteEvent:FireServer(targetPos)
        end
    end
end)

-- รันระบบ
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
Players.PlayerAdded:Connect(CreateESP)

print("Cheating Pro Master V1: อัปเดตระบบล็อคเป้าแล้ว!")
