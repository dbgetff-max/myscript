-- [[ CHEATING PRO MASTER V1 - ALL TEAMS AUTO KILL & ESP ]] --
-- ระบบ: ยิงฝ่ายตรงข้ามอัตโนมัติ + มองทะลุ (รองรับทุกทีม)

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 1. ระบบมองทะลุ (ESP) - เห็นทุกคนในเซิร์ฟเวอร์
local function CreateESP(Player)
    local function SetupESP(Character)
        local Head = Character:WaitForChild("Head", 10)
        if Head then
            local bgui = Instance.new("BillboardGui", Head)
            bgui.Name = "MasterESP"
            bgui.AlwaysOnTop = true
            bgui.Size = UDim2.new(0, 200, 0, 50)
            bgui.StudsOffset = Vector3.new(0, 2, 0)

            local nametag = Instance.new("TextLabel", bgui)
            nametag.BackgroundTransparency = 1
            nametag.Size = UDim2.new(1, 0, 1, 0)
            nametag.TextSize = 14
            nametag.Font = Enum.Font.SourceSansBold
            
            RunService.Heartbeat:Connect(function()
                if Player and Player.Parent and Character and Character:FindFirstChild("Head") then
                    local teamName = Player.Team and Player.Team.Name or "No Team"
                    nametag.Text = Player.Name .. " [" .. teamName .. "]"
                    
                    -- เปลี่ยนสีตามทีม
                    if teamName == "Police" or teamName == "Guards" then
                        nametag.TextColor3 = Color3.fromRGB(0, 150, 255) -- ตำรวจสีฟ้า
                    elseif teamName == "Criminals" then
                        nametag.TextColor3 = Color3.fromRGB(255, 0, 0) -- โจรสีแดง
                    else
                        nametag.TextColor3 = Color3.fromRGB(255, 255, 255) -- นักโทษ/อื่นๆ สีขาว
                    end
                else
                    bgui:Destroy()
                end
            end)
        end
    end
    if Player.Character then SetupESP(Player.Character) end
    Player.CharacterAdded:Connect(SetupESP)
end

-- 2. ระบบยิงอัตโนมัติ (Auto Kill Enemies)
RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    if not LocalPlayer.Team then return end

    for _, target in pairs(Players:GetPlayers()) do
        if target ~= LocalPlayer and target.Team and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            
            -- ตรวจสอบว่าเป็นศัตรูหรือไม่ (อยู่คนละทีมกัน)
            if target.Team ~= LocalPlayer.Team then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - target.Character.HumanoidRootPart.Position).Magnitude
                
                if dist < 50 then -- ระยะยิง 50 เมตร
                    local gun = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if gun and gun:FindFirstChild("RemoteEvent") then
                        -- ส่งคำสั่งยิงไปที่พิกัดศัตรู
                        gun.RemoteEvent:FireServer(target.Character.HumanoidRootPart.Position)
                        
                        -- ถ้าเป็นเกม Prison Life แบบเก่า (ดึงเลือดโดยตรง)
                        if target.Character:FindFirstChild("Humanoid") then
                            target.Character.Humanoid.Health = 0
                        end
                    end
                end
            end
        end
    end
end)

-- เริ่มทำงาน
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then CreateESP(p) end
end
Players.PlayerAdded:Connect(CreateESP)

print("Cheating Pro Master V1: ระบบ All-in-One พร้อมใช้งาน!")
