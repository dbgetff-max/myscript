-- [[ CHEATING PRO MASTER V1 - FINAL EDITION ]] --
-- ระบบ: มองทะลุ (แยกสีทีมชัดเจน) + ยิงทีมตรงข้ามออโต้ (ระยะ 200 เมตร)

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- ตั้งค่าระยะการยิง (200 คือระยะที่กระสุนปืนไปถึงและไม่โดนเตะ)
_G.ShootRange = 200 

-- 1. ระบบ ESP (มองทะลุแยกโทนสี)
local function CreateESP(Player)
    Player.CharacterAdded:Connect(function(Character)
        local Head = Character:WaitForChild("Head", 10)
        local bgui = Instance.new("BillboardGui", Head)
        bgui.Name = "MasterESP"
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 200, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 2.5, 0) -- ยกชื่อให้สูงขึ้นนิดนึงจะได้ไม่บังหน้า

        local nametag = Instance.new("TextLabel", bgui)
        nametag.BackgroundTransparency = 1
        nametag.Size = UDim2.new(1, 0, 1, 0)
        nametag.TextSize = 16
        nametag.Font = Enum.Font.SourceSansBold
        nametag.TextStrokeTransparency = 0 -- ขอบตัวหนังสือสีดำให้อ่านง่าย
        
        RunService.Heartbeat:Connect(function()
            if Player and Player.Parent and Character and Character:FindFirstChild("Head") then
                local team = Player.Team and Player.Team.Name or "Neutral"
                nametag.Text = Player.Name .. " [" .. team .. "]"
                
                -- [[ ปรับโทนสีให้มองง่ายที่สุด ]] --
                if team == "Police" or team == "Guards" then 
                    nametag.TextColor3 = Color3.fromRGB(0, 191, 255) -- Deep Sky Blue (ฟ้าสด)
                elseif team == "Criminals" then 
                    nametag.TextColor3 = Color3.fromRGB(255, 0, 50)   -- Bright Red (แดงเข้ม/โจร)
                elseif team == "Prisoners" then 
                    nametag.TextColor3 = Color3.fromRGB(255, 170, 0) -- Vivid Orange (ส้มทอง/นักโทษ)
                else 
                    nametag.TextColor3 = Color3.fromRGB(255, 255, 255) -- White (ขาว/ทั่วไป)
                end
            else 
                bgui:Destroy() 
            end
        end)
    end)
end

-- 2. ระบบยิงอัตโนมัติ (Auto Kill)
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    
    -- ต้องถือปืนที่มีระบบ RemoteEvent (เช่น ปืนใน Prison Life)
    if tool and tool:FindFirstChild("RemoteEvent") then
        for _, target in pairs(Players:GetPlayers()) do
            -- ยิงเฉพาะคนละทีมเท่านั้น
            if target ~= LocalPlayer and target.Team and target.Team ~= LocalPlayer.Team then
                local tChar = target.Character
                if tChar and tChar:FindFirstChild("HumanoidRootPart") and tChar:FindFirstChild("Humanoid") and tChar.Humanoid.Health > 0 then
                    
                    local dist = (char.HumanoidRootPart.Position - tChar.HumanoidRootPart.Position).Magnitude
                    
                    -- เช็คระยะว่าไม่เกิน 200 เมตร
                    if dist <= _G.ShootRange then
                        tool.RemoteEvent:FireServer(tChar.HumanoidRootPart.Position)
                    end
                end
            end
        end
    end
end)

-- รันระบบให้กับผู้เล่นทุกคน
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
Players.PlayerAdded:Connect(CreateESP)

print("Cheating Pro Master V1: พร้อมใช้งานแล้ว! (โทนสีใหม่ + ระยะยิง 200m)")
