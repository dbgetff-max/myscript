-- [[ CHEATING PRO MASTER V8 - THE REAL RECOVERY ]] --
-- แก้ไข: ระบบยิงแบบ V1 + เห็นโจรสีแดง + เห็นนักโทษสีส้ม + เป้าเขียว

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- ตั้งค่าความโหด (อ้างอิงจากคลิป V1 ที่คุณเล่นแล้วเทพ)
local SHOOT_RANGE = 250 
local FOV_SIZE = 130 

-- 1. วงกลมสีเขียว (กลับมาใช้แบบเดิมที่มองเห็นชัด)
local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = true
FOVCircle.Color = Color3.fromRGB(0, 255, 0)
FOVCircle.Thickness = 1
FOVCircle.NumSides = 64
FOVCircle.Radius = FOV_SIZE
FOVCircle.Transparency = 0.7
FOVCircle.Filled = false

-- 2. ระบบ ESP แยกสี (แก้บัคมองไม่เห็นโจร)
local function CreateESP(Player)
    local function AddTag(Character)
        local Head = Character:WaitForChild("Head", 10)
        if Head:FindFirstChild("V8_ESP") then Head.V8_ESP:Destroy() end

        local bgui = Instance.new("BillboardGui", Head)
        bgui.Name = "V8_ESP"
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 200, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 3, 0)

        local label = Instance.new("TextLabel", bgui)
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.TextSize = 18
        label.Font = Enum.Font.SourceSansBold
        label.TextStrokeTransparency = 0
        
        RunService.Heartbeat:Connect(function()
            if Player and Player.Parent and Character and Character:FindFirstChild("Head") then
                local team = Player.Team and Player.Team.Name or "None"
                label.Text = Player.Name .. " [" .. team .. "]"
                
                -- [[ เช็คชื่อทีมทุกแบบที่เป็นไปได้ ]] --
                if team == "Police" or team == "Guards" then 
                    label.TextColor3 = Color3.fromRGB(0, 162, 255) -- ฟ้า
                elseif team == "Criminals" or team == "Cowboys" then 
                    label.TextColor3 = Color3.fromRGB(255, 0, 0)   -- แดง (โจรต้องเห็น!)
                elseif team == "Inmates" or team == "Prisoners" then 
                    label.TextColor3 = Color3.fromRGB(255, 165, 0) -- ส้ม (นักโทษ)
                else 
                    label.TextColor3 = Color3.fromRGB(255, 255, 255) -- ขาว
                end
            else 
                bgui:Destroy() 
            end
        end)
    end
    if Player.Character then AddTag(Player.Character) end
    Player.CharacterAdded:Connect(AddTag)
end

-- 3. ระบบยิงอัตโนมัติ (ใช้ระบบ V1 ที่ดีที่สุด)
RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local char = LocalPlayer.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    
    if tool and tool:FindFirstChild("RemoteEvent") then
        for _, target in pairs(Players:GetPlayers()) do
            -- ยิงเฉพาะศัตรู (ไม่ยิงทีมเดียวกัน)
            if target ~= LocalPlayer and target.Team ~= LocalPlayer.Team then
                local tChar = target.Character
                if tChar and tChar:FindFirstChild("HumanoidRootPart") and tChar.Humanoid.Health > 0 then
                    local pos = tChar.HumanoidRootPart.Position
                    local screenPos, onScreen = Camera:WorldToViewportPoint(pos)
                    
                    -- ยิงเมื่ออยู่ในวงกลม FOV และในระยะที่กำหนด
                    if onScreen then
                        local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - FOVCircle.Position).Magnitude
                        local worldDist = (char.HumanoidRootPart.Position - pos).Magnitude
                        
                        if mouseDist < FOV_SIZE and worldDist < SHOOT_RANGE then
                            tool.RemoteEvent:FireServer(pos)
                        end
                    end
                end
            end
        end
    end
end)

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

print("V8: ระบบดั้งเดิมกลับมาแล้ว! เห็นโจรแดง นักโทษส้ม แน่นอน")
