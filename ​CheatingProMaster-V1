-- [[ Eleven Heaven: Prison Life God V22 - 100% AIMLOCK ]] --
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local camera = workspace.CurrentCamera
local runService = game:GetService("RunService")
local core = game:GetService("CoreGui")

-- ลบ UI เก่าป้องกันบัค
if core:FindFirstChild("ElevenPrisonGod") then core.ElevenPrisonGod:Destroy() end

local sg = Instance.new("ScreenGui", core)
sg.Name = "ElevenPrisonGod"

-- [[ 1. วงกลม FOV สีเขียว (จุดตัดสินความเป็นตาย) ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Color = Color3.new(0, 1, 0)
FOVCircle.Thickness = 2
FOVCircle.Filled = false
FOVCircle.Radius = 150 
FOVCircle.Visible = true
FOVCircle.Transparency = 1

runService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(mouse.X, mouse.Y + 36)
end)

-- [[ 2. ฟังก์ชันล็อคเป้าแบบ 100% (เช็คเป้าที่ใกล้จุดศูนย์กลางที่สุด) ]] --
local function getClosestTarget()
    local target = nil
    local shortestDistance = FOVCircle.Radius

    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Team ~= player.Team and v.Character and v.Character:FindFirstChild("Head") then
            if v.Character.Humanoid.Health > 0 then
                local pos, onScreen = camera:WorldToViewportPoint(v.Character.Head.Position)
                if onScreen then
                    local distance = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if distance < shortestDistance then
                        target = v.Character.Head
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return target
end

-- [[ 3. UI Menu สไตล์ Big Foot ]] --
local Main = Instance.new("Frame", sg)
Main.Size = UDim2.new(0, 350, 0, 350)
Main.Position = UDim2.new(0.5, -175, 0.5, -175)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.Visible = false
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main)

local ToggleBtn = Instance.new("TextButton", sg)
ToggleBtn.Size = UDim2.new(0, 45, 0, 45)
ToggleBtn.Position = UDim2.new(0, 10, 0.4, 0)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
ToggleBtn.Text = "🎯"
Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1, 0)
ToggleBtn.Activated:Connect(function() Main.Visible = not Main.Visible end)

local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(1, -110, 1, -10)
Scroll.Position = UDim2.new(0, 105, 0, 5)
Scroll.BackgroundTransparency = 1
Scroll.CanvasSize = UDim2.new(0, 0, 4, 0)
Instance.new("UIListLayout", Scroll).Padding = UDim.new(0, 5)

local FOVLabel = Instance.new("TextLabel", Scroll)
FOVLabel.Size = UDim2.new(0.95, 0, 0, 30); FOVLabel.BackgroundTransparency = 1
FOVLabel.TextColor3 = Color3.new(0, 1, 0); FOVLabel.Text = "FOV Radius: " .. tostring(FOVCircle.Radius); FOVLabel.Font = Enum.Font.GothamBold

local function CreateBtn(name, color, func)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.95, 0, 0, 35); btn.BackgroundColor3 = color; btn.Text = name; btn.TextColor3 = Color3.new(1, 1, 1); btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn); btn.Activated:Connect(func)
    return btn
end

-- [[ --- ฟังชั่นหลัก --- ]] --

CreateBtn("ปรับ FOV เป็น 600 (กว้างสุด)", Color3.fromRGB(150, 0, 0), function()
    FOVCircle.Radius = 600
    FOVLabel.Text = "FOV Radius: 600"
end)

CreateBtn("ปรับ FOV เป็น 150 (ปกติ)", Color3.fromRGB(50, 50, 50), function()
    FOVCircle.Radius = 150
    FOVLabel.Text = "FOV Radius: 150"
end)

_G.Aimbot = true
CreateBtn("ระบบล็อค 100%: ON/OFF", Color3.fromRGB(0, 150, 0), function(self)
    _G.Aimbot = not _G.Aimbot
    self.Text = _G.Aimbot and "ระบบล็อค 100%: ON" or "ระบบล็อค 100%: OFF"
end)

-- ระบบเทพ (ล็อคแล้วส่ง Remote ยิงทันที)
runService.RenderStepped:Connect(function()
    if _G.Aimbot then
        local target = getClosestTarget()
        if target then
            local tool = player.Character:FindFirstChildOfClass("Tool")
            if tool then
                -- ส่งสัญญาณยิงตรงเข้าหัว (100% Accuracy)
                local event = game:GetService("ReplicatedStorage"):FindFirstChild("ShootEvent")
                if event then
                    event:FireServer({
                        [1] = target,
                        [2] = target.Position,
                        [3] = tool
                    })
                end
            end
        end
    end
end)

