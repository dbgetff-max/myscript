-- [[ Eleven's Nightmare: Jumpscare & Map Wipe ]] --
-- คอนเซปต์: เสียงดังสนั่น + จอขาว + รีเซ็ตทั้งแมพ

local player = game.Players.LocalPlayer

-- [[ ระบบ UI หน้าสุดเสมอ ]] --
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.DisplayOrder = 999999

local MainFrame = Instance.new("Frame")
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
MainFrame.Position = UDim2.new(0.4, 0, 0.02, 0) -- ไว้บนสุดของจอ
MainFrame.Size = UDim2.new(0, 180, 0, 50)
MainFrame.Draggable = true

local StartBtn = Instance.new("TextButton")
StartBtn.Parent = MainFrame
StartBtn.Size = UDim2.new(1, 0, 1, 0)
StartBtn.Text = "ปล่อยคำสาป (สะดุ้งทั้งเกาะ)"
StartBtn.TextColor3 = Color3.new(1, 1, 1)
StartBtn.BackgroundTransparency = 1
StartBtn.Font = Enum.Font.GothamBold
StartBtn.TextSize = 14

-- [[ ฟังก์ชันคำสาป ]] --
local function LaunchNightmare()
    -- 1. ประกาศข้อความข่มขวัญ
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
        "หลับใหลไปในฝันร้ายของ Macbook Eleven...!", "All"
    )

    -- 2. รันระบบสำหรับทุกคนในเซิร์ฟ
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character then
            -- ใส่เสียงที่ดังและน่าตกใจ (Airhorn / Explosion)
            local sound = Instance.new("Sound")
            sound.SoundId = "rbxassetid://143570537" -- เสียง Airhorn ดังๆ
            sound.Volume = 10
            sound.Parent = v.Character:FindFirstChild("HumanoidRootPart") or workspace
            sound:Play()

            -- ทำให้ตัวละครเขาดีดขึ้นฟ้า (สะดุ้งของจริง)
            if v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.Velocity = Vector3.new(0, 200, 0)
            end

            -- สั่งรีเซ็ตหลังจากตกใจ 0.5 วินาที
            task.delay(0.5, function()
                if v.Character and v.Character:FindFirstChild("Humanoid") then
                    v.Character.Humanoid.Health = 0
                end
            end)
        end
    end
end

StartBtn.Activated:Connect(LaunchNightmare)
