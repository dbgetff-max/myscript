-- GitHub: dbgetff-max

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local HakiStatus = false 
local cooldown = false

-- [[ ระบบเสียงฮาคิ ]] --
local HakiSound = Instance.new("Sound")
HakiSound.SoundId = "rbxassetid://6551500742" -- เสียงฮาคิราชันย์แชงคูส
HakiSound.Volume = 5
HakiSound.Parent = game:GetService("SoundService")

-- [[ ส่วนของ UI ]] --
local ScreenGui = Instance.new("ScreenGui")
local ToggleFrame = Instance.new("Frame")
local ToggleButton = Instance.new("TextButton")
local StatusLabel = Instance.new("TextLabel")
local UICorner = Instance.new("UICorner")

ScreenGui.Parent = game.CoreGui
ToggleFrame.Parent = ScreenGui
ToggleFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
ToggleFrame.Position = UDim2.new(0.85, 0, 0.4, 0)
ToggleFrame.Size = UDim2.new(0, 120, 0, 60)
ToggleFrame.Active = true
ToggleFrame.Draggable = true
UICorner.Parent = ToggleFrame

ToggleButton.Parent = ToggleFrame
ToggleButton.Size = UDim2.new(1, 0, 0.6, 0)
ToggleButton.Position = UDim2.new(0, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
ToggleButton.Text = "RELEASE"
ToggleButton.TextColor3 = Color3.new(1, 1, 1)
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.TextSize = 14

StatusLabel.Parent = ToggleFrame
StatusLabel.Size = UDim2.new(1, 0, 0.4, 0)
StatusLabel.Text = "HAKI: OFF"
StatusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
StatusLabel.BackgroundTransparency = 1
StatusLabel.Font = Enum.Font.GothamBold

-- [[ ฟังก์ชันปล่อยพลังพร้อมเสียง ]] --
local function executeHaki()
    if not HakiStatus or cooldown then return end
    cooldown = true
    
    -- เล่นเสียงแชงคูส
    HakiSound:Play()
    
    -- ประกาศแชท
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
        "[ พลังแห่งราชันย์: จงสยบแทบเท้า Macbook Eleven! ]", 
        "All"
    )

    -- เอฟเฟกต์หน้าจอสั่นและทำให้คนสลบ (PlatformStand)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            local dist = (player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if dist < 35 then
                v.Character.Humanoid.PlatformStand = true
                task.delay(4, function() v.Character.Humanoid.PlatformStand = false end)
            end
        end
    end
    
    task.wait(5) -- คูลดาวน์เสียง
    cooldown = false
end

-- ระบบ Toggle และการกดปุ่ม
StatusLabel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        HakiStatus = not HakiStatus
        StatusLabel.Text = HakiStatus and "HAKI: ON" or "HAKI: OFF"
        StatusLabel.TextColor3 = HakiStatus and Color3.fromRGB(170, 0, 255) or Color3.fromRGB(255, 0, 0)
    end
end)

ToggleButton.MouseButton1Click:Connect(executeHaki)
mouse.KeyDown:Connect(function(key) if key:lower() == "h" then executeHaki() end end)
