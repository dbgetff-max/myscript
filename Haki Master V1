local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")

-- [[ ระบบ UI ]] --
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local TornadoBtn = Instance.new("TextButton")
local QuakeBtn = Instance.new("TextButton")
local UICorner = Instance.new("UICorner")

ScreenGui.Parent = game.CoreGui
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(0, 50, 100)
MainFrame.Position = UDim2.new(0.7, 0, 0.4, 0)
MainFrame.Size = UDim2.new(0, 150, 0, 110)
MainFrame.Active = true
MainFrame.Draggable = true
UICorner.Parent = MainFrame

-- ปุ่มเสกพายุ
TornadoBtn.Parent = MainFrame
TornadoBtn.Size = UDim2.new(0.9, 0, 0.4, 0)
TornadoBtn.Position = UDim2.new(0.05, 0, 0.05, 0)
TornadoBtn.Text = "เสกพายุหมุน"
TornadoBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
TornadoBtn.TextColor3 = Color3.new(1, 1, 1)

-- ปุ่มแผ่นดินไหว
QuakeBtn.Parent = MainFrame
QuakeBtn.Size = UDim2.new(0.9, 0, 0.4, 0)
QuakeBtn.Position = UDim2.new(0.05, 0, 0.55, 0)
QuakeBtn.Text = "แผ่นดินไหว"
QuakeBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
QuakeBtn.TextColor3 = Color3.new(1, 1, 1)

-- [[ ฟังก์ชันเสกพายุ (Tornado) ]] --
TornadoBtn.MouseButton1Click:Connect(function()
    print("ปลดปล่อยพายุแห่ง Eleven!")
    local tornadoPart = Instance.new("Part")
    tornadoPart.Anchored = true
    tornadoPart.CanCollide = false
    tornadoPart.Position = root.Position + Vector3.new(0, 10, 0)
    tornadoPart.Size = Vector3.new(1, 1, 1)
    tornadoPart.Transparency = 0.5
    tornadoPart.Parent = workspace
    
    -- สร้างเอฟเฟกต์หมุนวน
    task.spawn(function()
        for i = 1, 100 do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local targetRoot = v.Character.HumanoidRootPart
                    local dist = (tornadoPart.Position - targetRoot.Position).Magnitude
                    if dist < 40 then
                        -- ดูดคนเข้าหาพายุและหมุน
                        targetRoot.CFrame = targetRoot.CFrame * CFrame.Angles(0, math.rad(20), 0)
                        targetRoot.Velocity = Vector3.new(0, 50, 0) -- ทำให้ตัวลอย
                    end
                end
            end
            task.wait(0.1)
        end
        tornadoPart:Destroy()
    end)
end)

-- [[ ฟังก์ชันแผ่นดินไหว (Earthquake) ]] --
QuakeBtn.MouseButton1Click:Connect(function()
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
        "[ ภัยพิบัติ: แผ่นดินไหวโดย Macbook Eleven! ]", "All"
    )
    for i = 1, 20 do
        local shake = Vector3.new(math.random(-2,2), 0, math.random(-2,2))
        workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame * CFrame.new(shake)
        task.wait(0.05)
    end
end)
