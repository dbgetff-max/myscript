-- [[ Eleven's Portal & Wipe: ดึงมาตบถล่มเกาะ ]] --
-- คอนเซปต์: วาร์ปทุกคนมาตรงหน้า > ระเบิดเปรี้ยงเดียว > หายทั้งเซิร์ฟ

local player = game.Players.LocalPlayer
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.DisplayOrder = 999999

local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.Size = UDim2.new(0, 180, 0, 130)
Frame.Position = UDim2.new(0.4, 0, 0.1, 0)
Frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- สีดำขรึม
Frame.Active = true
Frame.Draggable = true
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

-- [[ ปุ่มที่ 1: ดึงทุกคนมาหาเรา (Bring Everyone) ]] --
local BringBtn = Instance.new("TextButton")
BringBtn.Parent = Frame
BringBtn.Size = UDim2.new(0.9, 0, 0.4, 0)
BringBtn.Position = UDim2.new(0.05, 0, 0.05, 0)
BringBtn.Text = "ดึงมาที่นี่! 🌀"
BringBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
BringBtn.TextColor3 = Color3.new(1, 1, 1)
BringBtn.Font = Enum.Font.GothamBold
BringBtn.TextSize = 16

BringBtn.Activated:Connect(function()
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("🌀 ทุกคนจงมาหา Macbook Eleven! 🌀", "All")
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, -5) -- ดึงมาอยู่ข้างหน้าเรา 5 หน่วย
            end
        end
    end
end)

-- [[ ปุ่มที่ 2: ระเบิดล้างบาง (Boom Wipe) ]] --
local WipeBtn = Instance.new("TextButton")
WipeBtn.Parent = Frame
WipeBtn.Size = UDim2.new(0.9, 0, 0.4, 0)
WipeBtn.Position = UDim2.new(0.05, 0, 0.55, 0)
WipeBtn.Text = "ระเบิดตู้ม! 💣"
WipeBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
WipeBtn.TextColor3 = Color3.new(1, 1, 1)
WipeBtn.Font = Enum.Font.GothamBold
WipeBtn.TextSize = 16

WipeBtn.Activated:Connect(function()
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("💣 ลาก่อนพวกมนุษย์... ตู้มมม! 💣", "All")
    
    -- เอฟเฟกต์ระเบิด (เราเห็นคนเดียวแต่เสียงกับดาเมจคนอื่นโดน)
    local explosion = Instance.new("Explosion")
    explosion.Position = player.Character.HumanoidRootPart.Position
    explosion.BlastRadius = 100
    explosion.Parent = workspace

    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            v.Character.Humanoid.Health = 0 -- สั่งตายทันที
        end
    end
end)
