-- [[ ฟังก์ชันการทำงาน ]] --
local function runHeavenlyWay()
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
        "[ วิถีสวรรค์: มหันตภัยถมเกาะโดย Macbook Eleven... ]", "All"
    )
    
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 120, 0)
    bv.MaxForce = Vector3.new(0, math.huge, 0)
    bv.Parent = root
    
    task.wait(3)
    bv:Destroy()
    
    local exp = Instance.new("Explosion")
    exp.Position = root.Position
    exp.BlastRadius = 2500 -- ขยายให้กว้างขึ้นอีก
    exp.Parent = workspace
    
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            v.Character.Humanoid.Health = 0
        end
    end
    
    task.wait(0.1)
    player.Character.Humanoid.Health = 0
end

-- แก้ไขจุดนี้: ใช้ทั้ง Click และ Touch เพื่อให้กดได้แน่นอน
StartBtn.MouseButton1Click:Connect(runHeavenlyWay)
StartBtn.TouchTap:Connect(runHeavenlyWay)
