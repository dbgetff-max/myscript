-- [[ ฟังก์ชันมหาเวทย์วิถีสวรรค์ ]] --
StartBtn.MouseButton1Click:Connect(function()
    -- 1. ประกาศศักดา (ประกาศแชท)
    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
        "[ วิถีสวรรค์: มหันตภัยถมเกาะโดย Macbook Eleven... จงหายไปให้หมด! ]", "All"
    )
    
    -- 2. ทะยานขึ้นสู่ท้องฟ้า (สูงมากเพื่อให้เห็นทั่วเกาะ)
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 100, 0)
    bv.MaxForce = Vector3.new(0, math.huge, 0)
    bv.Parent = root
    
    task.wait(3.5) -- บินขึ้นไปสูงๆ
    bv:Destroy()
    
    -- 3. เอฟเฟกต์แสงระเบิดมหาศาล
    local exp = Instance.new("Explosion")
    exp.Position = root.Position
    exp.BlastRadius = 2000 -- รัศมีถมเกาะ
    exp.BlastPressure = 0 -- ไม่ให้ของกระเด็นจนเซิร์ฟค้าง แต่เน้นฆ่า
    exp.Parent = workspace
    
    -- 4. ส่งทุกคนไปเกิดใหม่ (Reset Everyone)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            -- ไม่ต้องเช็คระยะ เพราะรัศมี 2000 คือทั่วแมพ Brookhaven แล้ว
            v.Character.Humanoid.Health = 0
        end
    end
    
    -- 5. ตัวเราสละชีพเพื่อความเท่
    task.wait(0.1)
    hum.Health = 0
end)
