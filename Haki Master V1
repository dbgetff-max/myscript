local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")

-- [[ ระบบ UI ]] --
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local StartBtn = Instance.new("TextButton")
local UICorner = Instance.new("UICorner")
local UIStroke = Instance.new("UIStroke")

ScreenGui.Parent = game.CoreGui
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
MainFrame.Position = UDim2.new(0.8, 0, 0.45, 0)
MainFrame.Size = UDim2.new(0, 150, 0, 70)
MainFrame.Active = true
MainFrame.Draggable = true
UICorner.Parent = MainFrame

UIStroke.Parent = MainFrame
UIStroke.Thickness = 3
UIStroke.Color = Color3.fromRGB(255, 215, 0) -- ขอบสีทองแบบเทพเจ้า

StartBtn.Parent = MainFrame
StartBtn.Size = UDim2.new(1, 0, 1, 0)
StartBtn.Text = "ล้างเกาะ!"
StartBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
